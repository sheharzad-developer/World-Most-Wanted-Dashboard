# Copy this file to .env and fill in your values.
# Never commit .env (it is in .gitignore).

# MongoDB connection string (local or Atlas).
# For Atlas: mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/myDatabase?retryWrites=true&w=majority
# Encode @ in password as %40
MONGODB_URI=mongodb://localhost:27017

# MONGODB_URL=mongodb+srv://sheharzadsalahuddin9000_db_user:Zain%40245@cluster0.gmxh1je.mongodb.net/myDatabase?retryWrites=true&w=majority&appName=Cluster0

# Optional: port for local server (default 3000)
PORT=3000
